{
  "compilerOptions": {
    "module": "commonjs",
    "sourceMap": true,
    "esModuleInterop": true,
    "noImplicitAny": false,
    "target": "ES2022",
    "preserveWatchOutput": true,
    "strictFunctionTypes": false,
    "strictNullChecks": false,
    "types": ["node"],
    "useUnknownInCatchVariables": false
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "transforms/__testfixtures__/**"]
}
